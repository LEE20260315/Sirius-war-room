# 默认:文本文件按 LF 存储与检出(Git 内部 blob 始终是 LF)
* text=auto eol=lf

# Windows 专用脚本必须保留 CRLF(PowerShell/IIS 对 CRLF 敏感)
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# 二进制文件:不做换行符转换,不做 diff
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
